# ============================================================
# Backend Environment Configuration Template
# ============================================================
# Copy this file to .env and update with your actual values
# Command: cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# DATABASE CONNECTION
# ------------------------------------------------------------
# Individual components (config.py builds DATABASE_URL automatically)
# For local dev: localhost
# For Docker: Use container name (portfolio_db)
DB_HOST=localhost
DB_PORT=5432
DB_USER=portfolio_user
DB_PASSWORD=changeme

# Database name
DB_NAME=portfolio

# ------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ------------------------------------------------------------
# SECRET_KEY: JWT token signing (CRITICAL - must be secret)
# Generate with: openssl rand -base64 48
SECRET_KEY=your-secret-key-change-in-production

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------
# Comma-separated allowed origins (no spaces)
CORS_ORIGINS=http://localhost:3000,http://localhost

# ------------------------------------------------------------
# ADMIN USER
# ------------------------------------------------------------
# Required for database seeding and admin panel access
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-strong-password-here

# ------------------------------------------------------------
# CLOUDFLARE R2 STORAGE
# ------------------------------------------------------------
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://uploads.heistats.com

# ------------------------------------------------------------
# OPTIONAL: SENTRY ERROR TRACKING
# ------------------------------------------------------------
# Get from: https://sentry.io
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# ============================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================
# Docker: DB_HOST should be service name (portfolio_db)
# Cloud Run: Use Unix socket for Cloud SQL
# Always use strong, randomly generated passwords
# Never commit .env with real credentials
# ============================================================

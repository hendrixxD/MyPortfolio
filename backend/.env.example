# Database
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=changeme

# Backend
DATABASE_URL=postgresql://portfolio_user:changeme@postgres:5432/portfolio
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost

# Admin User (required for database seeding and admin access)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-strong-password-here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production overrides (for production environment)
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# CORS_ORIGINS=https://yourdomain.com

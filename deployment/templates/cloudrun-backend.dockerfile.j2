# Cloud Run Backend Dockerfile
# Generated at: {{ config._generated_at }}
# Environment: {{ config.ENVIRONMENT }}

FROM python:3.12-slim

# Set labels
LABEL maintainer="{{ config.get('ADMIN_EMAIL', 'admin@example.com') }}"
LABEL environment="{{ config.ENVIRONMENT }}"
LABEL target="cloudrun"

# Set working directory
WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    gcc \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better layer caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Create necessary directories
RUN mkdir -p /app/uploads /app/logs && \
    chmod 755 /app/uploads /app/logs

# Expose port (Cloud Run uses PORT env var, default to 8080)
ENV PORT=8080
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Run uvicorn with Cloud Run optimizations
# - Use multiple workers for better concurrency
# - Listen on 0.0.0.0 to accept external requests
# - Use PORT environment variable from Cloud Run
CMD uvicorn app.main:app \
    --host 0.0.0.0 \
    --port $PORT \
    --workers {{ config.get('UVICORN_WORKERS', '2') }} \
    --log-level {{ config.get('LOG_LEVEL', 'info') }} \
    --access-log
